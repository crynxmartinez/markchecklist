generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  MODULE_ADMIN
  USER
}

enum Module {
  RECRUITMENT
  TRUCK_MANAGEMENT
  ANALYTICS
  ONBOARDING
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  role         Role     @default(USER)
  modules      Module[]
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Agent {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  phone            String?
  status           String?   // Active, Inactive, Part Time, Processing
  leadTeam         String?   // Active, Inactive, Processing
  coach            String?   // Kiona Grantham, Mario Munoz, Melissa Perla, N/A
  agentDevelopment String?   // Yes, No
  dre              String?   // DRE License number
  dreExpiration    DateTime? // DRE Expiration date
  birthday         String?   // Month Day format (e.g., "April 2")
  anniversary      String?   // MM-DD-YYYY format
  language         String?   // Spanish, Romanian, etc.
  mlsId            String?   // MLS ID
  subscription     String?   // Yes, No, Outside
  tc               String?   // Transaction Coordinator (Alexis, Kenia, Outside)
  source           String?   // Referral, FB, etc.
  ghlContactId     String?   // Link to GHL contact if exists
  checklistState   Json      @default("[]")
  percentage       Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Contact {
  id                String   @id @default(cuid())
  ghlContactId      String   @unique
  firstName         String?
  lastName          String?
  email             String?
  phone             String?
  tags              String[]
  source            String?
  subAccount        String?
  recruitmentStage  String?
  dateAdded         DateTime?
  lastUpdated       DateTime?
  customFields      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tasks             Task[]
  notes             Note[]
}

model PipelineStage {
  id        String   @id @default(cuid())
  name      String
  order     Int
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String    @id @default(cuid())
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Note {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  content   String
  ghlNoteId String?  @unique
  isFromGHL Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConversationRead {
  id               String   @id @default(cuid())
  ghlConversationId String  @unique
  readAt           DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Transaction module (mirrors "Transaction Sheet 2026" workbook)
// ---------------------------------------------------------------------------

enum TransactionStatus {
  PENDING
  CLOSED
  CANCELLED
}

enum ListingStatus {
  ACTIVE
  CLOSED
  CANCELLED
  EXPIRED
}

// Unifies "Pending 2026", "Closed 2026", "Cancelled 2026" and the
// "Pending 2026 connected to Form" intake into a single record.
model Transaction {
  id        String            @id @default(cuid())
  status    TransactionStatus @default(PENDING)

  // Property
  coeMonth        String?
  side            String? // "Buyer" / "Seller"
  propertyAddress String?
  city            String?
  state           String?
  zipCode         String?
  county          String?

  // People
  agentName   String?
  agentPhone  String?
  agentEmail  String?
  pm          String? // Production Manager
  isa         String?
  tc          String? // Transaction Coordinator
  tcEmail     String?
  clientName  String?
  clientPhone String?
  clientEmail String?

  // Vendors / contacts
  otherAgentName    String?
  otherAgentContact String?
  escrowContact     String?
  escrowPhone       String?
  escrowEmail       String?
  lender            String?
  lenderPhone       String?
  lenderEmail       String?
  homeWarranty      String?
  nhd               String?
  title             String?

  // Dates / quarters
  quarterAccepted String?
  acceptanceDate  DateTime?
  contractCoe     DateTime?
  closingDate     DateTime?
  quarterClosed   String?

  // Property details (from intake form)
  solar      String?
  hoa        String?
  septic     String?
  termite    String?
  contingent String?
  notes      String?
  uploads    String?

  // Financials
  leadSource          String?
  purchasePrice       Float?
  commissionPct       Float?
  gci                 Float?
  transactionFee      Float?
  tcFee               Float?
  adminFee            Float?
  listingAddOn        Float?
  agentFeeCollected   Float?
  additionalCollected Float?
  additionalDeduction Float?
  referralAmt         Float?
  sellerAdvance       Float?
  commissionType      String?
  grossTotal          Float?
  teamTotal           Float?
  agentEstimate       Float?

  // Follow-up / CRM
  vaUpdate             String?
  zillowPastSale       String?
  reviewActionPlanSent String?

  // Cancellation
  clientStatus          String?
  dateOfCancellation    DateTime?
  cancelledBy           String?
  reasonForCancellation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([agentName])
  @@index([quarterClosed])
}

// Unifies "Listing Board 2026" and "Closed Canc Exp 2026".
model Listing {
  id     String        @id @default(cuid())
  status ListingStatus @default(ACTIVE)

  listingServices String?
  listingShowcase String?
  listingAgent    String?
  tc              String?
  address         String?
  signUpDown      String?
  listingPrice     Float?
  listingStartDate DateTime?
  listingExpDate   DateTime?
  takeSheetReceived String?
  commission       Float?
  closingNotes     String?
  sellerAdvance    Float?
  agentFee         String? // mixed values e.g. "Agent Pay", "695"
  sellersHwOrder   String?
  daysOffMarket    String?
  todaysDate       DateTime?
  trustNameOrEntity String?

  clientLegalName String?
  clientPhone     String?
  clientEmail     String?

  reasonForCancellation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([listingAgent])
}

// "Referrals" tab.
model Referral {
  id String @id @default(cuid())

  referralType    String?
  dealType        String?
  side            String? // "Seller" / "Buyer"
  propertyAddress String?
  city            String?
  zipCode         String?
  county          String?

  agentName   String?
  isa         String?
  am          String?
  principal   String?
  clientPhone String?
  clientEmail String?

  recipientAgent       String?
  recipientAgentBroker String?
  rfaStatus            String?

  acceptanceDate     DateTime?
  contractClosedDate DateTime?
  actualClosingDate  DateTime?

  leadSource         String?
  purchasePrice      Float?
  commission         String? // "$" or "%" mixed
  gci                Float?
  referralAmount     Float?
  commissionType       String?
  grossTotal           Float?
  teamTotal            Float?
  agentEstimate        Float?
  commissionAdjustments String?
  agentCommission      Float?
  escrowDisbursement   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rfaStatus])
  @@index([agentName])
}

// "Agent Reimbursements" tab.
model Reimbursement {
  id      String  @id @default(cuid())
  agent   String?
  listing String?
  item    String?
  amount  Float?
  notes   String?
  status  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// "Agent Contracts" tab (onboarding + commission terms).
model AgentContract {
  id        String @id @default(cuid())
  agentName String?

  soi                  Float?
  chtContractSent      DateTime?
  chtContractSigned    DateTime?
  chtContractEffective DateTime?
  anniversaryDate      DateTime?
  dateToReviewSoiSplit DateTime?
  expContractSigned    String?
  dateOnboardingCompleted DateTime?
  soiCap               String?
  referralAgent        String?
  productionManager    String?
  dateAssignedToPm     String?
  eaProgramAssignedDate String?
  transactionsPaidEa   String?
  tcServicesSubscribedDate String?
  fubAccount           String?
  disc                 String?
  adminBill            String?
  source               String?
  zillowAccountabilityAgreement String?
  payNotes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentName])
}
